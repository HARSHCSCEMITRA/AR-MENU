{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" }
  ],
  "routes": [
    { "src": "/restaurant/login(.html)?", "dest": "/restaurant/login.html" },
    { "src": "/restaurant/signup(.html)?", "dest": "/restaurant/signup.html" },
    { "src": "/restaurant/dashboard(.html)?", "dest": "/restaurant/dashboard.html" },
    { "src": "/restaurant/dishes(.html)?", "dest": "/restaurant/dishes.html" },
    { "src": "/restaurant/qr-codes(.html)?", "dest": "/restaurant/qr-codes.html" },
    { "src": "/restaurant/3d-models(.html)?", "dest": "/restaurant/3d-models.html" },
    { "src": "/restaurant/analytics(.html)?", "dest": "/restaurant/analytics.html" },
    { "src": "/restaurant/subscription(.html)?", "dest": "/restaurant/subscription.html" },
    { "src": "/restaurant/settings(.html)?", "dest": "/restaurant/settings.html" },
    { "src": "/restaurant/forgot(.html)?", "dest": "/restaurant/forgot.html" },
    { "src": "/ar/demo(.html)?", "dest": "/ar/demo.html" },
    { "src": "/ar(/index.html)?", "dest": "/ar/index.html" },
    { "src": "/admin(/index.html)?", "dest": "/admin/index.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
